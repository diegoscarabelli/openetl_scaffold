# Copy to .env and fill in your values. .env is gitignored — never commit real credentials.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=system2_pipelines_db
DB_USER=system2_pipelines
DB_PASSWORD=

# Or provide a full SQLAlchemy URL (takes precedence over DB_* vars):
# DATABASE_URL=postgresql+psycopg://system2_pipelines:password@localhost:5432/system2_pipelines_db

# Base directory for pipeline data. Defaults to ./data relative to repo root.
DATA_DIR=./data

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
