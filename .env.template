# Environment Configuration Template
# Copy this file to .env and customize the values for your environment.
# .env is gitignored — never commit real credentials.

# ======================================================================================
# REQUIRED: Analytics database connection
# Uses SQL_DB_* prefix (not DB_*) to avoid conflicts with Airflow's entrypoint script,
# which reserves DB_HOST for health-check logic. Setting DB_HOST as a container
# environment variable causes Redis broker connection failures.
# Prefect (local): use localhost when running flows directly on the host.
# Astronomer/Airflow (Docker): use host.docker.internal (Mac/Windows) or
# 172.17.0.1 (Linux Docker Engine) to reach the host DB from containers.
# ======================================================================================
SQL_DB_HOST=localhost
SQL_DB_PORT=5432
SQL_DB_NAME=lens
SQL_DB_USER=data_pipelines
SQL_DB_PASSWORD=

# ======================================================================================
# OPTIONAL: Full SQLAlchemy URL (takes precedence over SQL_DB_* vars)
# Uncomment and set to override the individual SQL_DB_* variables above.
# ======================================================================================
# DATABASE_URL=postgresql+psycopg://data_pipelines:password@localhost:5432/lens

# ======================================================================================
# OPTIONAL: Pipeline data directory (ingest/process/store/quarantine)
# Defaults to ./data relative to repo root.
# For Astronomer/Docker setups, use an absolute host-side path.
# IMPORTANT: Docker Compose does NOT expand ~ — use absolute paths only.
# Example: /home/username/pipeline_data
# ======================================================================================
DATA_DIR=./data

# ======================================================================================
# OPTIONAL: Logging level
# ======================================================================================
LOG_LEVEL=INFO

# ======================================================================================
# ENVIRONMENTS
# To target the dev database, change SQL_DB_NAME above to lens_dev.
# Both databases are created by database.ddl. Run schemas.ddl and iam.sql against
# each database you use.
# ======================================================================================
